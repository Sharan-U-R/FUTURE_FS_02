{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "GENERATE_SOURCEMAP": "false",
    "BROWSERSLIST_IGNORE_OLD_DATA": "1",
    "CI": "false",
    "SKIP_PREFLIGHT_CHECK": "true"
  },
  "installCommand": "npm install --ignore-scripts",
  "buildCommand": "npm run build"
}